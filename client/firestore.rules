rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tasks collection — users can only access their own tasks
    match /tasks/{taskId} {
      // Read / update / delete: only if the stored userId field matches the caller
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;

      // Create: only if the new document's userId matches the caller
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

  }
}
