# Firebase Client SDK Credentials (from Firebase Console -> Project Settings -> General)
# Optional in dev: If missing, Taskly runs in zero-config offline DEV MOCK mode!
VITE_FIREBASE_API_KEY="__YOUR_API_KEY__"
VITE_FIREBASE_AUTH_DOMAIN="__YOUR_AUTH_DOMAIN__"
VITE_FIREBASE_PROJECT_ID="__YOUR_PROJECT_ID__"
VITE_FIREBASE_STORAGE_BUCKET="__YOUR_STORAGE_BUCKET__"
VITE_FIREBASE_MESSAGING_SENDER_ID="__YOUR_SENDER_ID__"
VITE_FIREBASE_APP_ID="__YOUR_APP_ID__"

# API Backend Base URL
VITE_API_URL="http://localhost:5000/api"
