# Server Port
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL default)
DATABASE_URL="postgresql://postgres:postgres_secure_password@localhost:5432/taskly?schema=public"

# SQLite Alternative connection string:
# DATABASE_URL="file:./dev.db"

# Firebase Admin SDK credentials (from Firebase Console -> Project Settings -> Service Accounts)
# Optional in dev: If missing, Taskly runs in zero-config offline DEV MOCK mode!
FIREBASE_PROJECT_ID="__YOUR_PROJECT_ID__"
FIREBASE_CLIENT_EMAIL="__YOUR_CLIENT_EMAIL__"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n__YOUR_PRIVATE_KEY__\n-----END PRIVATE KEY-----\n"

# Frontend URL (for CORS)
CLIENT_URL="http://localhost:5173"
